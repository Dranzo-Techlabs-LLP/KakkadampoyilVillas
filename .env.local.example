# Email delivery for the enquiry form
# Copy this file to .env.local and fill in the values, then restart `npm run dev`.
# If these are not set, enquiries will be logged to the server console only.

# Where enquiries are sent (override default).
ENQUIRY_TO_EMAIL=shinky777@gmail.com

# SMTP credentials.
# Gmail example: create an App Password (myaccount.google.com/apppasswords)
# and use it as SMTP_PASS. SMTP_USER is your full Gmail address.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=your-gmail@gmail.com
